<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0"
            prefWidth="900.0"
            style="-fx-background-color: #F6EDDC;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.template.MainController">

    <children>

        <VBox spacing="15.0"
              AnchorPane.topAnchor="15.0"
              AnchorPane.bottomAnchor="15.0"
              AnchorPane.leftAnchor="15.0"
              AnchorPane.rightAnchor="15.0">

            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <children>

                <!-- CABEÇALHO -->
                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      style="-fx-background-color: #C53557;
                             -fx-background-radius: 15;
                             -fx-padding: 15;">

                    <children>

                        <Label text="📚"
                               style="-fx-font-size: 28px;"/>

                        <Label text="Sistema de Cadastro de Livros"
                               textFill="#F6EDDC">
                            <font>
                                <Font size="24"/>
                            </font>
                        </Label>

                    </children>

                </HBox>

                <!-- MENSAGENS -->
                <Label fx:id="lblMensagem"
                       alignment="CENTER"
                       maxWidth="Infinity"
                       text="Pronto para cadastrar livros."
                       style="-fx-background-color: white;
                              -fx-background-radius: 10;
                              -fx-padding: 10;
                              -fx-font-weight: bold;
                              -fx-text-fill: #3B1C22;" />

                <!-- CONTADOR -->
                <HBox alignment="CENTER_RIGHT">

                    <children>

                        <Label text="Total de livros: "
                               style="-fx-font-weight: bold;"/>

                        <Label fx:id="lblTotal"
                               text="0"
                               style="-fx-font-weight: bold;
                                      -fx-text-fill: #C53557;"/>

                    </children>

                </HBox>

                <!-- TABELA -->
                <TableView fx:id="tblLivro"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #C53557;
                                  -fx-border-width: 2;
                                  -fx-padding: 5;">

                    <columns>

                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="70"/>

                        <TableColumn fx:id="colTitulo"
                                     text="Título"
                                     prefWidth="250"/>

                        <TableColumn fx:id="colAutor"
                                     text="Autor"
                                     prefWidth="220"/>

                        <TableColumn fx:id="colGenero"
                                     text="Gênero"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colPaginas"
                                     text="Páginas"
                                     prefWidth="100"/>

                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                </TableView>

                <TitledPane text="📖 Dados do Livro"
                            expanded="true"
                            collapsible="false">

                    <content>

                        <VBox spacing="15"
                              style="-fx-background-color: #FBA8AF;
                                     -fx-background-radius: 10;
                                     -fx-padding: 15;
                                    -fx-border-radius: 10;
                                  -fx-border-color: #C53557;
                                  -fx-border-width: 2;">

                            <children>

                                <!-- ID + TÍTULO -->
                                <HBox spacing="10"
                                      alignment="CENTER_LEFT">

                                    <children>

                                        <Label text="ID"
                                               prefWidth="30"
                                               style="-fx-font-weight: bold;"/>

                                        <TextField fx:id="txtId"
                                                   editable="false"
                                                   prefWidth="70"
                                                   style="-fx-background-color: #EAEAEA;
                                          -fx-background-radius: 8;
                                          -fx-border-radius: 8;
                                          -fx-border-color: #C53557;"/>

                                        <Label text="Título"
                                               prefWidth="55"
                                               style="-fx-font-weight: bold;"/>

                                        <TextField fx:id="txtTitulo"
                                                   promptText="Digite o título do livro"
                                                   HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: #F6EDDC;
                                          -fx-background-radius: 8;
                                          -fx-border-radius: 8;
                                          -fx-border-color: #C53557;"/>

                                    </children>

                                </HBox>

                                <!-- AUTOR -->
                                <HBox spacing="10"
                                      alignment="CENTER_LEFT">

                                    <children>

                                        <Label text="Autor"
                                               prefWidth="70"
                                               style="-fx-font-weight: bold;"/>

                                        <TextField fx:id="txtAutor"
                                                   promptText="Digite o nome do autor"
                                                   HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: #F6EDDC;
                                          -fx-background-radius: 8;
                                          -fx-border-radius: 8;
                                          -fx-border-color: #C53557;"/>

                                    </children>

                                </HBox>

                                <!-- GÊNERO -->
                                <HBox spacing="10"
                                      alignment="CENTER_LEFT">

                                    <children>

                                        <Label text="Gênero"
                                               prefWidth="70"
                                               style="-fx-font-weight: bold;"/>

                                        <ComboBox fx:id="cbGenero"
                                                  promptText="Selecione o gênero"
                                                  HBox.hgrow="ALWAYS"
                                                  style="-fx-background-radius: 8;
                                         -fx-border-radius: 8;
                                         -fx-border-color: #C53557;"/>

                                    </children>

                                </HBox>

                                <!-- PÁGINAS -->
                                <HBox spacing="10"
                                      alignment="CENTER_LEFT">

                                    <children>

                                        <Label text="Nº Páginas"
                                               prefWidth="70"
                                               style="-fx-font-weight: bold;"/>

                                        <TextField fx:id="txtPaginas"
                                                   promptText="Ex: 250"
                                                   prefWidth="180"
                                                   style="-fx-background-color: #F6EDDC;
                                          -fx-background-radius: 8;
                                          -fx-border-radius: 8;
                                          -fx-border-color: #C53557;"/>

                                    </children>

                                </HBox>

                            </children>

                        </VBox>

                    </content>

                </TitledPane>
                <!-- BOTÕES -->
                <HBox spacing="15"
                      alignment="CENTER_RIGHT">

                    <children>

                        <Button fx:id="btnSalvar"
                                text="💾 Salvar"
                                prefWidth="130"
                                prefHeight="40"
                                onAction="#btnSalvarAction"
                                style="-fx-background-color: #C53557;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;" />

                        <Button fx:id="btnAlterar"
                                text="✏ Alterar"
                                prefWidth="130"
                                prefHeight="40"
                                onAction="#btnAlterarAction"
                                style="-fx-background-color: #FBA8AF;
                                       -fx-text-fill: #3B1C22;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;" />

                        <Button fx:id="btnDeletar"
                                text="🗑 Excluir"
                                prefWidth="130"
                                prefHeight="40"
                                onAction="#btnDeletarAction"
                                style="-fx-background-color: #C53557;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;" />

                        <Button fx:id="btnLimpar"
                                text="🧹 Limpar"
                                prefWidth="130"
                                prefHeight="40"
                                onAction="#btnLimparAction"
                                style="-fx-background-color: #FBA8AF;
                                       -fx-text-fill: #3B1C22;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;" />

                    </children>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>